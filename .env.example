# GovGraph configuration
#
# Copy to .env and fill in values.

# Protect GovGraph itself (optional). If set, clients must send X-Api-Key header.
GOVGRAPH_API_KEY=

# Database path (SQLite)
GOVGRAPH_DB_PATH=govgraph.db

# Upstream keys (optional but recommended)
GOVGRAPH_API_DATA_GOV_KEY=

# Upstream base URLs (override if endpoints change)
GOVGRAPH_SAM_OPPORTUNITIES_BASE_URL=https://api.sam.gov/prod/opportunities/v2/search
GOVGRAPH_SAM_ENTITY_BASE_URL=https://api.sam.gov/entity-information/v3/entities
GOVGRAPH_SAM_EXCLUSIONS_BASE_URL=https://api.sam.gov/entity-information/v3/exclusions
GOVGRAPH_USASPENDING_BASE_URL=https://api.usaspending.gov/api/v2

# Background polling for webhook alerts
GOVGRAPH_ENABLE_POLLER=false
GOVGRAPH_POLL_INTERVAL_SECONDS=300
GOVGRAPH_WEBHOOK_TIMEOUT_SECONDS=10
